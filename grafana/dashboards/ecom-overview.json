{
  "id": null,
  "uid": "ecom-overview",
  "title": "Ecom Realtime - Overview",
  "tags": ["ecom"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "Orders Placed (Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(orders_placed_total) or vector(0)",
          "legendFormat": "Orders"
        }
      ]
    },
    {
      "id": 2,
      "title": "Payment Success Rate (%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(payment_success_total) / (sum(payment_success_total) + sum(payment_failed_total)) * 100 or vector(0)",
          "legendFormat": "Success %"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (job) (rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "p95 Latency by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (job, le) (rate(http_server_requests_seconds_bucket[1m])))",
          "legendFormat": "{{job}} p95"
        }
      ]
    },
    {
      "id": 5,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "kafka_consumer_fetch_manager_records_lag{job=~\".*service.*\"}",
          "legendFormat": "{{job}} - {{topic}}"
        }
      ]
    }
  ]
}
